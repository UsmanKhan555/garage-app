generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now())
  vehicles Vehicle[]
}

model Vehicle {
  id        Int     @id @default(autoincrement())
  make      String
  model     String
  plateNumber String
  customerId Int 
  customer Customer @relation(fields: [customerId], references: [id])
}
